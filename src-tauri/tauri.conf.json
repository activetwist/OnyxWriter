{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Onyx Writer",
  "version": "0.1.12",
  "identifier": "app.onyxwriter.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Onyx Writer",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBODY3NzczMzg2RkQwRjcKUldUMzBHODRjM2VHK3RRSzZ3Q2JORVpJU3p6VnpXck9oQjdkTm1wR2YrUU92Qk5lVzRxMkcxQmcK",
      "endpoints": [
        "https://github.com/activetwist/OnyxWriter/releases/latest/download/latest.json"
      ]
    }
  }
}
