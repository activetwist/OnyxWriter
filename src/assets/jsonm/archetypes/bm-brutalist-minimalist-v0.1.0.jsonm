        "dangerSurfaceSubtle": "rgba(0, 0, 0, 0.04)",
        "dangerSurfaceSoft": "rgba(0, 0, 0, 0.08)",
        "dangerSurfaceSoftStrong": "rgba(0, 0, 0, 0.12)",
        "dangerBorderSoft": "rgba(0, 0, 0, 0.30)",
        "dangerBorderSoftStrong": "rgba(0, 0, 0, 0.40)",
        "accentSurfaceSubtlest": "rgba(0, 0, 0, 0.03)",
        "accentSurfaceSubtle": "rgba(0, 0, 0, 0.06)",
        "accentSurfaceSoft": "rgba(0, 0, 0, 0.10)",
