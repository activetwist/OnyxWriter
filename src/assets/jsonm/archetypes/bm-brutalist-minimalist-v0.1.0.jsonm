        "accentBorderSoft": "rgba(0, 0, 0, 0.30)",
        "textOverlay": "#000000aa",
        "dangerHover": "#000000"
      }
    },
    "shadow": {
      "none": "none",
      "sm": "none",
      "md": "none"
    },
    "motion": {
      "duration": {
        "none": "0ms",
        "fast": "120ms",
        "normal": "180ms"
      },
      "easing": {
        "standard": "cubic-bezier(0.2, 0, 0, 1)"
      }
    },
    "layout": {
      "containers": {
        "sm": "720px",
        "md": "960px",
        "lg": "1120px"
      },
