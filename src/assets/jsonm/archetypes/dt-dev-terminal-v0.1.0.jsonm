{
  "schemaVersion": "1",
  "format": "JSONM",
  "kind": "named",
  "id": "dt",
  "name": "Dev Terminal",
  "description": "Technical, confident, crafted. Near-black canvas with near-white text and a single saturated accent, monospace-forward typography, functional-soft radii, and a luminance-stacking depth philosophy. For developer tools, technical documentation, and software products where precision and craft signal competence.",
  "corpus": {
    "id": "activetwist-design-corpus/v1",
    "version": "apollo-v0.1.0",
    "canonical": true,
    "sourceFiles": [
      "app/tokens.css",
      "app/runtime-fonts.css",
      "app/runtime-token-overrides.css"
    ]
  },
  "settings": {
    "wcagPolicy": "AA",
    "appearanceModes": [
      "light",
      "dark"
    ],
    "systemFollow": false,
    "defaultMode": "dark"
  },
  "tokens": {
